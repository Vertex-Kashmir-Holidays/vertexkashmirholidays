# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── Auth.js v5 ────────────────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"

# ── App URLs ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
REVALIDATE_SECRET="your-revalidate-secret"

# Branded placeholder image used for seeded/empty image slots (full URL). The
# host is added to next.config image remotePatterns, so change both together.
NEXT_PUBLIC_PLACEHOLDER_IMAGE="https://vertexkashmirholidays.vercel.app/uploads/general/1782136262740-dy3wqa.svg"


# ── Hero mode ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_HERO_MODE="parallax"       # parallax | r3f | spline
NEXT_PUBLIC_SPLINE_URL=""              # Optional Spline scene URL


# ── Razorpay ──────────────────────────────────────────────────────────────────
# Keys: Razorpay Dashboard → Settings → API Keys (use rzp_test_* in test mode,
# rzp_live_* in production). KEY_ID + SECRET are server-only; NEXT_PUBLIC_* is the
# same key id exposed to the checkout widget. Amounts are always recomputed
# server-side (price × travellers; 10% advance or full) — the client is never trusted.
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_SECRET="your-razorpay-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
#
# Webhook (async payment confirmation — keeps the ledger correct even if the
# customer closes the tab after paying):
#   1. Razorpay Dashboard → Settings → Webhooks → Add New Webhook.
#   2. Webhook URL:  https://<your-domain>/api/bookings/webhook
#      (local testing: expose localhost with a tunnel, e.g.
#       https://<id>.ngrok-free.app/api/bookings/webhook)
#   3. Active events: payment.captured, payment.failed, order.paid
#   4. Set a Secret and paste the SAME value here. The route verifies the
#      raw-body HMAC-SHA256 against this secret, so it must match exactly.
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"
#
# Troubleshooting payments — a booking is stuck PENDING after a successful payment:
#   Cause: the customer paid (Razorpay captured), but the post-payment write was
#   missed — usually the DB was briefly unreachable when /api/bookings/verify-payment
#   ran, AND the webhook wasn't configured/reachable (it can't hit localhost without
#   a tunnel). The money is NOT lost.
#   Recovery (any of these — all idempotent, none double-charge/double-email):
#     • Admin → open the booking → "Verify Payment" (re-queries Razorpay and records
#       the captured payment, links the customer, sends the emails).
#     • Configure the webhook (above) — Razorpay retries it, so it self-heals.
#   Note: serverless Postgres (e.g. Neon free tier) auto-suspends after short idle;
#   the gap while the customer is on the Razorpay screen can hit that window. Use an
#   always-on / paid DB in production, and keep the webhook configured as the safety net.


# ── Media storage (Cloudinary) ───────────────────────────────────────────────
# When set, uploads go to Cloudinary (required on any deployed env — VPS, Vercel, Docker).
# When unset, uploads fall back to writing local public/uploads/ (local dev only).
# Either provide the single URL form...
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"
# ...or the three discrete vars instead:
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Root folder inside your Cloudinary account. Use different values per environment
# to keep uploads separated (e.g. dev vs production).
# dev server: CLOUDINARY_FOLDER="vertex-kashmir/dev"
# production:  CLOUDINARY_FOLDER="vertex-kashmir/prod"
# Falls back to "vertexkashmir" when unset.
CLOUDINARY_FOLDER="vertex-kashmir/dev"

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"
MAIL_FROM="Vertex Kashmir Holidays <hello@vertexkashmirholidays.com>"
MAIL_TO_ADMIN="admin@vertexkashmirholidays.com"
# Dedicated inbox for public lead-form notifications. Falls back to MAIL_TO_ADMIN
# (then MAIL_FROM) when unset.
LEADS_EMAIL="hello@vertexkashmirholidays.com"
BOOKING_EMAIL="hello@vertexkashmirholidays.com"

# ── Anti-bot: Cloudflare Turnstile (CAPTCHA) ─────────────────────────────────
# Free, privacy-friendly CAPTCHA on the public + auth forms. When the SECRET is
# unset, server-side verification is SKIPPED (dev) and the client widget is not
# rendered unless the public SITE key is set. Set both in production to enforce.
# Create keys at https://dash.cloudflare.com → Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY="******"
TURNSTILE_SITE_KEY="*******"        # (optional mirror of the public key, for reference)
TURNSTILE_SECRET_KEY="******"

# ── Anti-bot: Upstash Redis (rate limiting) ──────────────────────────────────
# Durable per-IP / per-phone / per-email rate limiting that works on Vercel.
# When unset, the limiter falls back to a per-instance in-memory store (best
# effort, resets on redeploy). Create a free DB at https://console.upstash.com.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""




# ── Analytics: Google Tag Manager + GA4 ─────────────────────────────────────
# GTM container ID (format: GTM-XXXXXXX). All tags (GA4, ads, etc.) are managed
# in GTM — do not add gtag.js directly. Leave blank to disable analytics.
NEXT_PUBLIC_GTM_ID="GTM-*******"
# GA4 Measurement ID — configure inside GTM as a GA4 tag, not directly in code.
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-*******"
