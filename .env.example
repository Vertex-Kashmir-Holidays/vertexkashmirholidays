# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── Auth.js v5 ────────────────────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"

# ── App URLs ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
REVALIDATE_SECRET="your-revalidate-secret"

# Branded placeholder image used for seeded/empty image slots (full URL). The
# host is added to next.config image remotePatterns, so change both together.
NEXT_PUBLIC_PLACEHOLDER_IMAGE="https://vertexkashmirholidays.vercel.app/uploads/general/1782136262740-dy3wqa.svg"

# ── Hero mode ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_HERO_MODE="parallax"       # parallax | r3f | spline
NEXT_PUBLIC_SPLINE_URL=""              # Optional Spline scene URL

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_SECRET="your-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"

# ── Media storage (Cloudinary) ───────────────────────────────────────────────
# When set, uploads go to Cloudinary (required on Vercel — its fs is read-only).
# When unset, uploads fall back to local public/uploads (dev only).
# Either provide the single URL form...
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"
# ...or the three discrete vars instead:
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"
MAIL_FROM="Vertex Kashmir Holidays <hello@vertexkashmirholidays.com>"
MAIL_TO_ADMIN="admin@vertexkashmirholidays.com"
# Dedicated inbox for public lead-form notifications. Falls back to MAIL_TO_ADMIN
# (then MAIL_FROM) when unset.
LEADS_EMAIL="leads@vertexkashmirholidays.com"

# ── Anti-bot: Cloudflare Turnstile (CAPTCHA) ─────────────────────────────────
# Free, privacy-friendly CAPTCHA on the public + auth forms. When the SECRET is
# unset, server-side verification is SKIPPED (dev) and the client widget is not
# rendered unless the public SITE key is set. Set both in production to enforce.
# Create keys at https://dash.cloudflare.com → Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SITE_KEY=""        # (optional mirror of the public key, for reference)
TURNSTILE_SECRET_KEY=""

# ── Anti-bot: Upstash Redis (rate limiting) ──────────────────────────────────
# Durable per-IP / per-phone / per-email rate limiting that works on Vercel.
# When unset, the limiter falls back to a per-instance in-memory store (best
# effort, resets on redeploy). Create a free DB at https://console.upstash.com.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
