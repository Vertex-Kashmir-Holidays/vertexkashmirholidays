datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum TourCategory {
  HONEYMOON
  FAMILY
  ADVENTURE
  LUXURY
}

enum BookingStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum InquiryStatus {
  NEW
  CONTACTED
  CONVERTED
  CLOSED
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  passwordHash String
  role         Role      @default(USER)
  bookings     Booking[]
  reviews      Review[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
}

model Destination {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String?
  excerpt     String?
  coverImage  String?
  location    String?
  tours       TourDestination[]
  metaTitle   String?
  metaDesc    String?
  ogImage     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([slug])
}

model Tour {
  id           String            @id @default(cuid())
  title        String
  slug         String            @unique
  excerpt      String?
  description  String?
  category     TourCategory
  duration     Int
  coverImage   String?
  // JSON strings (SQLite has no native arrays)
  gallery      String            @default("[]")
  itinerary    String            @default("[]")
  inclusions   String            @default("[]")
  exclusions   String            @default("[]")
  priceFrom    Float
  priceWas     Float?
  discountPct  Int?
  bestseller   Boolean           @default(false)
  rating       Float             @default(0)
  reviewCount  Int               @default(0)
  published    Boolean           @default(false)
  destinations TourDestination[]
  bookings     Booking[]
  reviews      Review[]
  metaTitle    String?
  metaDesc     String?
  ogImage      String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([slug])
  @@index([category])
  @@index([published])
  @@index([bestseller])
}

model TourDestination {
  id            String      @id @default(cuid())
  tourId        String
  destinationId String
  tour          Tour        @relation(fields: [tourId], references: [id], onDelete: Cascade)
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@unique([tourId, destinationId])
  @@index([tourId])
  @@index([destinationId])
}

model Booking {
  id              String        @id @default(cuid())
  tourId          String
  userId          String?
  tour            Tour          @relation(fields: [tourId], references: [id])
  user            User?         @relation(fields: [userId], references: [id])
  status          BookingStatus @default(PENDING)
  razorpayOrderId String        @unique
  razorpayPayId   String?
  amount          Float
  currency        String        @default("INR")
  travelDate      DateTime
  travellers      Int           @default(1)
  guestName       String
  guestEmail      String
  guestPhone      String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([tourId])
  @@index([userId])
  @@index([createdAt])
}

model Inquiry {
  id         String        @id @default(cuid())
  name       String
  phone      String
  email      String?
  travelDate DateTime?
  travellers Int?
  message    String?
  source     String?       @default("website")
  status     InquiryStatus @default(NEW)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Review {
  id        String   @id @default(cuid())
  tourId    String
  userId    String?
  tour      Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
  name      String
  rating    Int
  body      String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tourId])
  @@index([approved])
}

model Blog {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  body        String?
  coverImage  String?
  author      String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  metaTitle   String?
  metaDesc    String?
  ogImage     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([published])
  @@index([publishedAt])
}

model Gallery {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  caption   String?
  category  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model SiteSettings {
  id          String   @id @default("singleton")
  siteName    String   @default("Vertex Kashmir Holidays")
  siteTagline String?
  siteEmail   String?
  sitePhone   String?
  siteAddress String?
  whatsapp    String?
  facebook    String?
  instagram   String?
  twitter     String?
  youtube     String?
  metaTitle   String?
  metaDesc    String?
  ogImage     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
