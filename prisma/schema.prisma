datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum TourCategory {
  HONEYMOON
  FAMILY
  ADVENTURE
  LUXURY
}

enum BookingStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum InquiryStatus {
  NEW
  CONTACTED
  CONVERTED
  CLOSED
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  passwordHash String
  role         Role      @default(USER)
  bookings     Booking[]
  reviews      Review[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
}

model Destination {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String?
  excerpt     String?
  tagline     String?
  coverImage  String?
  location    String?
  isFeatured  Boolean           @default(false)
  sortOrder   Int               @default(0)
  tours       TourDestination[]
  metaTitle   String?
  metaDesc    String?
  ogImage     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([slug])
}

model Tour {
  id           String            @id @default(cuid())
  title        String
  slug         String            @unique
  excerpt      String?
  description  String?
  category     TourCategory
  duration     Int
  coverImage   String?
  badge        String?
  badgeColor   String?           @default("green")
  tagline      String?
  // JSON strings (Postgres column kept as text for portability)
  gallery      String            @default("[]")
  itinerary    String            @default("[]")
  inclusions   String            @default("[]")
  exclusions   String            @default("[]")
  highlights   String            @default("[]") // JSON string[] — overview chips
  faqs         String            @default("[]") // JSON [{ question, answer }]
  // Quick-fact / info-card details surfaced on the tour detail page
  startCity    String?
  transport    String?
  difficulty   String?
  bestTime     String?
  tourType     String?
  pickupDrop   String?
  happyCount   Int?
  priceFrom    Float
  priceWas     Float?
  discountPct  Int?
  bestseller   Boolean           @default(false)
  rating       Float             @default(0)
  reviewCount  Int               @default(0)
  published    Boolean           @default(false)
  destinations TourDestination[]
  bookings     Booking[]
  reviews      Review[]
  metaTitle    String?
  metaDesc     String?
  ogImage      String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([slug])
  @@index([category])
  @@index([published])
  @@index([bestseller])
}

model TourDestination {
  id            String      @id @default(cuid())
  tourId        String
  destinationId String
  tour          Tour        @relation(fields: [tourId], references: [id], onDelete: Cascade)
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@unique([tourId, destinationId])
  @@index([tourId])
  @@index([destinationId])
}

model Booking {
  id              String        @id @default(cuid())
  tourId          String
  userId          String?
  tour            Tour          @relation(fields: [tourId], references: [id])
  user            User?         @relation(fields: [userId], references: [id])
  status          BookingStatus @default(PENDING)
  razorpayOrderId String        @unique
  razorpayPayId   String?
  amount          Float
  currency        String        @default("INR")
  travelDate      DateTime
  travellers      Int           @default(1)
  guestName       String
  guestEmail      String
  guestPhone      String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([tourId])
  @@index([userId])
  @@index([createdAt])
}

model Inquiry {
  id         String        @id @default(cuid())
  name       String
  phone      String
  email      String?
  travelDate DateTime?
  travellers Int?
  message    String?
  source     String?       @default("website")
  status     InquiryStatus @default(NEW)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Review {
  id        String   @id @default(cuid())
  tourId    String
  userId    String?
  tour      Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
  name      String
  rating    Int
  body      String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tourId])
  @@index([approved])
}

model Blog {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  body        String?
  coverImage  String?
  author      String?
  authorImage String?
  authorRole  String?
  authorBio   String?
  category    String?
  readTime    Int?
  featured    Boolean   @default(false)
  trending    Boolean   @default(false)
  published   Boolean   @default(false)
  publishedAt DateTime?
  metaTitle   String?
  metaDesc    String?
  ogImage     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([published])
  @@index([publishedAt])
  @@index([featured])
  @@index([trending])
  @@index([category])
}

// Singleton copy block for the blog listing page (hero + sidebar widgets).
model BlogContent {
  id                    String   @id @default("singleton")
  heroKicker            String?
  heroTitle             String?
  heroSubtitle          String?
  heroImage             String?
  heroSearchPlaceholder String?
  aboutTitle            String?
  aboutText             String?
  aboutCtaLabel         String?
  aboutCtaHref          String?
  newsletterTitle       String?
  newsletterText        String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Blog filter chips + sidebar "Popular Categories" (counts derived from Blog).
model BlogCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  icon      String   @default("") // SVG path `d`
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model Gallery {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  caption   String?
  category  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

// ─────────────────────────────────────────────
// Home page content
// ─────────────────────────────────────────────

// Singleton copy block for the hero + about sections.
// Title strings support accent markers: *warm gradient* and ~cool gradient~.
model HomeContent {
  id                    String   @id @default("singleton")
  heroBadge             String?
  heroTitle             String?
  heroSubtitle          String?
  heroCtaPrimaryLabel   String?
  heroCtaPrimaryHref    String?
  heroCtaSecondaryLabel String?
  heroCtaSecondaryHref  String?
  formKicker            String?
  formTitle             String?
  formSubtitle          String?
  formButtonLabel       String?
  formNote              String?
  formAvatars           String   @default("[]") // JSON array of avatar URLs
  aboutPara1            String?
  aboutPara2            String?
  aboutImage1           String?
  aboutImage2           String?
  aboutCardEmoji        String?
  aboutCardTitle        String?
  aboutCardSubtitle     String?
  aboutRatingTitle      String?
  aboutRatingSubtitle   String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Per-section headings keyed by section slug
// (videos, packages, why, destinations, about, offers, testimonials, blogs)
model HomeSection {
  id        String   @id @default(cuid())
  key       String   @unique
  kicker    String?
  title     String?
  subtitle  String?
  ctaLabel  String?
  ctaHref   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HeroSlide {
  id        String   @id @default(cuid())
  image     String
  alt       String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// Counters shown in hero / about ("hero" | "about" section)
model SiteStat {
  id        String   @id @default(cuid())
  section   String
  label     String
  value     String
  suffix    String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([section, sortOrder])
}

// Marquee items in the updates strip
model TickerItem {
  id        String   @id @default(cuid())
  text      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model VideoReview {
  id        String   @id @default(cuid())
  name      String
  place     String?
  duration  String?
  thumbnail String
  videoUrl  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model WhyChooseItem {
  id          String   @id @default(cuid())
  emoji       String
  title       String
  description String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model Offer {
  id          String    @id @default(cuid())
  badge       String?
  title       String
  description String?
  image       String?
  price       Float
  oldPrice    Float?
  endsText    String?
  validUntil  DateTime?
  ctaHref     String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive, sortOrder])
}

// General site testimonials (not tied to a tour, unlike Review)
model Testimonial {
  id        String   @id @default(cuid())
  name      String
  location  String?
  avatar    String?
  quote     String
  rating    Int      @default(5)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// ─────────────────────────────────────────────
// About page content
// ─────────────────────────────────────────────

// Singleton copy block for every About page section.
// Title strings support mint accent markers (*text*) and \n line breaks.
model AboutContent {
  id                    String   @id @default("singleton")
  // Hero
  heroBreadcrumb        String?
  heroTitle             String?
  heroSubtitle          String?
  heroImage             String?
  heroCtaPrimaryLabel   String?
  heroCtaPrimaryHref    String?
  heroCtaSecondaryLabel String?
  heroCtaSecondaryHref  String?
  // Story
  storyKicker           String?
  storyTitle            String?
  storyBody             String?
  storyImage            String?
  // Stats strip background
  statsImage            String?
  // Values
  valuesKicker          String?
  valuesTitle           String?
  valuesSubtitle        String?
  // Team
  teamKicker            String?
  teamTitle             String?
  teamCtaLabel          String?
  teamCtaHref           String?
  // Journey
  journeyKicker         String?
  journeyTitle          String?
  // Press
  pressLabel            String?
  // Final CTA
  ctaTitle              String?
  ctaSubtitle           String?
  ctaImage              String?
  ctaWhatsappLabel      String?
  ctaWhatsappHref       String?
  ctaCallLabel          String?
  ctaCallHref           String?
  ctaEmailLabel         String?
  ctaEmailHref          String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Four feature chips in the Story section (title + subtitle + SVG path).
model AboutStoryFeature {
  id        String   @id @default(cuid())
  title     String
  subtitle  String
  icon      String // SVG path `d`
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// Counter cards in the About stats strip (value + label + SVG path).
model AboutStat {
  id        String   @id @default(cuid())
  value     String
  label     String
  icon      String // SVG path `d`
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// Value cards in the "Promises We Keep" section.
model AboutValue {
  id        String   @id @default(cuid())
  title     String
  subtitle  String
  icon      String // SVG path `d`
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// Team member cards.
model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  bio       String
  image     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// Timeline milestones in the Journey section.
model JourneyMilestone {
  id        String   @id @default(cuid())
  year      String
  detail    String
  icon      String // SVG path `d`
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// "As featured in" press logos (stored as inline HTML snippets).
model PressLogo {
  id        String   @id @default(cuid())
  html      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// ─────────────────────────────────────────────
// Contact page content
// ─────────────────────────────────────────────

// Singleton copy block for the contact page. Real contact details (phone,
// email, address, whatsapp, socials) come from SiteSettings.
model ContactContent {
  id                 String   @id @default("singleton")
  // Hero
  heroBreadcrumb     String?
  heroTitle          String?
  heroSubtitle       String?
  heroImage          String?
  // Reach section
  reachKicker        String?
  reachTitle         String?
  // Promise section
  promiseKicker      String?
  promiseTitle       String?
  // Office / map section
  officeKicker       String?
  officeTitle        String?
  officeSubtitle     String?
  officeName         String?
  officeAddress      String?
  officeHours        String?
  officeMapLabel     String?
  officeMapSubLabel  String?
  directionsUrl      String?
  // FAQs
  faqsKicker         String?
  faqsTitle          String?
  faqsCtaLabel       String?
  faqsCtaHref        String?
  // Testimonials
  testimonialsKicker String?
  testimonialsTitle  String?
  // Social
  socialKicker       String?
  socialTitle        String?
  socialText         String?
  socialCtaLabel     String?
  socialCtaHref      String?
  // Form
  formKicker         String?
  formTitle          String?
  formNote           String?
  // Floating WhatsApp button
  whatsappFloatText  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ContactHeroFeature {
  id        String   @id @default(cuid())
  title     String
  subtitle  String
  icon      String // SVG path `d`
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model ContactPromiseItem {
  id        String   @id @default(cuid())
  title     String
  subtitle  String
  icon      String // SVG path `d`
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model ContactFaq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model ContactOffice {
  id        String   @id @default(cuid())
  name      String
  address   String
  hours     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

// ─────────────────────────────────────────────
// Campaign landing pages (/campaign/[slug])
// ─────────────────────────────────────────────

// A self-contained marketing landing page. Structured sections are stored as
// JSON strings (same convention as Tour) and parsed in the page.
model Campaign {
  id             String   @id @default(cuid())
  slug           String   @unique
  published      Boolean  @default(false)
  // Theming
  accent         String   @default("hsl(196 90% 52%)")
  accent2        String   @default("hsl(170 80% 50%)")
  particles      String   @default("snow") // "snow" | "embers"
  // Hero
  name           String
  badge          String?
  titleHtml      String?
  sub            String?
  heroImage      String?
  finalImage     String?
  facts          String   @default("[]") // JSON string[]
  heroCta        String?
  proofCount     String?
  // Urgency bar
  offerText      String?
  offerDeadline  DateTime?
  offerSeats     String?
  // Nav / contact
  navCta         String?
  phone          String?
  whatsappHref   String?
  // Marquee
  strip          String   @default("[]") // JSON string[]
  // Stats — JSON [[value, suffix, label]]
  stats          String   @default("[]")
  // Film
  filmTitle      String?
  filmDuration   String?
  filmPoster     String?
  filmSrc        String?
  // Highlights — JSON [{ image, emoji, title, description }]
  highlightsTitle String?
  highlights     String   @default("[]")
  // Activities — JSON [{ image, title }]
  activitiesTitle String?
  activities     String   @default("[]")
  // Itinerary — JSON [{ title, description, image }]
  itineraryTitle String?
  itinerary      String   @default("[]")
  // Pricing — JSON [{ name, price, old, tag, desc, feats[] }]
  tiers          String   @default("[]")
  // Departures — JSON [{ date, seats, price, status }]
  batches        String   @default("[]")
  // Inclusions / exclusions — JSON string[]
  inclusions     String   @default("[]")
  exclusions     String   @default("[]")
  // Gallery — JSON string[] (image urls)
  galleryTitle   String?
  gallery        String   @default("[]")
  // Testimonials — JSON [{ image, name, location, quote }]
  testimonials   String   @default("[]")
  // FAQs — JSON [{ question, answer }]
  faqsTitle      String?
  faqs           String   @default("[]")
  // Final CTA
  finalTitle     String?
  finalSub       String?
  finalCta       String?
  finalNote      String?
  // SEO
  metaTitle      String?
  metaDesc       String?
  ogImage        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([slug])
  @@index([published])
}

model SiteSettings {
  id          String   @id @default("singleton")
  siteName    String   @default("Vertex Kashmir Holidays")
  siteTagline String?
  siteEmail   String?
  sitePhone   String?
  siteAddress String?
  whatsapp    String?
  facebook    String?
  instagram   String?
  twitter     String?
  youtube     String?
  metaTitle   String?
  metaDesc    String?
  ogImage     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
