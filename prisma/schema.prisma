  id                    String   @id @default("singleton")
  heroKicker            String?
  heroTitle             String?
  heroSubtitle          String?
  heroImage             String?
  heroSearchPlaceholder String?
  aboutTitle            String?
  aboutText             String?
  aboutCtaLabel         String?
  aboutCtaHref          String?
  newsletterTitle       String?
  newsletterText        String?
