  alt       String?
  caption   String?
  category  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([type])
}

// Long-form legal/policy pages (Terms, Privacy, Refund & Cancellation).
// Keyed by slug; content is admin-editable HTML. The app ships professional
// defaults so a page always renders even before a row exists.
model LegalPage {
  slug            String   @id // terms-and-conditions | privacy-policy | refund-and-cancellation
  title           String
  content         String // HTML
  heroImage       String? // desktop banner image (gallery URL); falls back to shipped default
  heroImageMobile String? // optional ≤640px banner image
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

