generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  phone        String?
  image        String? // profile picture URL (customer-managed in /account/profile)
  passwordHash String
  role         Role      @default(CUSTOMER)
  // Set true for accounts created with a system-generated temp password (e.g. from
  // lead conversion). Forces a password change on first login before any other
  // account access is allowed. Cleared once the customer sets their own password.
  mustChangePassword Boolean @default(false)
  // Sales incentive rate (percent) applied to a booking's PROFIT, not the booking
  // amount. Optional; only meaningful for SALES staff. Kept on the user so future
  // monthly salary/commission reports can compute payouts per salesperson.
  bookingConversionPct Float?
  deletedAt    DateTime? // soft-delete marker; non-null = hidden + login blocked
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  bookings      Booking[]
  reviews       Review[]
  itineraries       Itinerary[] @relation("ItineraryOwner")
  itinerariesEdited Itinerary[] @relation("ItineraryEditor")
  leadsAssigned Lead[]      @relation("LeadAssignee")
  notifications Notification[]
  // ── Vertex Connect ────────────────────────────────────────────────────────
  chatRoomsCreated    ChatRoom[]           @relation("ConnectRoomCreator")
  chatMemberships     ChatMember[]         @relation("ConnectMemberships")
  chatMessagesSent    ChatMessage[]        @relation("ConnectMessageSender")
  presence            UserPresence?
  meetingsCreated     Meeting[]            @relation("ConnectMeetingCreator")
  meetingParticipants MeetingParticipant[] @relation("ConnectMeetingParticipants")

  @@index([email])
  @@index([deletedAt])
}

// In-app notification for a staff user (e.g. a lead being assigned/reassigned).
// Best-effort, created alongside the equivalent email. `link` is an in-app path
// the bell dropdown deep-links to; `readAt` non-null = read.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // LEAD_ASSIGNED | LEAD_UNASSIGNED | …
  title     String
  body      String
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model Itinerary {
  id        String          @id @default(cuid())
  title     String
  status    ItineraryStatus @default(DRAFT)
  data      Json
  ownerId   String
  owner     User            @relation("ItineraryOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  // Optional link to a CRM lead. @unique enforces a single current itinerary per
  // lead. Cascade so deleting a (non-converted) lead cleans up its itinerary.
  leadId    String?         @unique
  lead      Lead?           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  // Optional link to a direct (website) booking — one current itinerary per
  // booking. Mutually exclusive with leadId in practice (a converted booking
  // uses its lead's itinerary). Cascade so deleting the booking cleans it up.
  bookingId String?         @unique
  booking   Booking?        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  // Locked when the owning lead is converted — the final, immutable itinerary.
  locked    Boolean         @default(false)
  // Last editor (creator is `owner`). SetNull so a deleted staff user is tolerated.
  lastEditedById String?
  lastEditedBy   User?       @relation("ItineraryEditor", fields: [lastEditedById], references: [id], onDelete: SetNull)
  history   ItineraryHistory[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([ownerId])
  @@index([status])
  @@index([updatedAt])
  @@index([lastEditedById])
}

// Append-only audit trail: one snapshot row per saved version of an itinerary.
// Lets us see what was shared/updated over time. Cascade-deleted with its parent.
model ItineraryHistory {
  id           String    @id @default(cuid())
  itineraryId  String
  itinerary    Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  title        String
  data         Json
  editedById   String?
  editedByName String
  createdAt    DateTime  @default(now())

  @@index([itineraryId])
  @@index([createdAt])
}

// Pending email-verification record for account registration. A row is created
// when a visitor requests a sign-up OTP; the account is NOT created in `User`
// until the OTP is verified. One pending row per email (email is unique) — a
// re-request upserts. The OTP is stored hashed (codeHash), never in plaintext,
// and the chosen password is stored already-bcrypt-hashed (passwordHash) so no
// plaintext credentials are ever persisted. Expired rows are cleaned up on each
// request/verify call (see src/lib/auth/otp.ts → cleanupExpiredOtps).
model EmailOtp {
  id           String   @id @default(cuid())
  email        String   @unique
  codeHash     String // bcrypt hash of the 6-digit OTP
  name         String // pending account display name
  passwordHash String // pending account password (already bcrypt-hashed)
  phone        String? // collected at sign-up; copied to User on verification
  attempts     Int      @default(0) // failed verification attempts
  expiresAt    DateTime // OTP expiry (now + 10 minutes)
  lastSentAt   DateTime @default(now()) // drives the 60s resend cooldown
  createdAt    DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model RolePermission {
  id        String  @id @default(cuid())
  role      Role
  module    String
  canView   Boolean @default(false)
  canCreate Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)

  @@unique([role, module])
}

model Destination {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String?
  excerpt     String?
  tagline     String?
  coverImage  String?
  location    String?
  // Display facts shown on cards + detail page (free-form, admin-editable).
  altitude    String? // e.g. "2,650 m"
  season      String? // best season, e.g. "Apr – Oct"
  region      String? // filter grouping, e.g. "Kashmir Valley" | "Ladakh"
  // Coordinates power the live weather widget (Open-Meteo).
  latitude    Float?
  longitude   Float?
  isFeatured  Boolean           @default(false)
  sortOrder   Int               @default(0)
  metaTitle   String?
  metaDesc    String?
  ogImage     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  tours       TourDestination[]
  activities  ActivityDestination[]

  @@index([slug])
}

// Things to do — a first-class admin entity linked many-to-many to destinations
// and tours. Public listing/detail pages are planned but not built yet.
model Activity {
  id          String                @id @default(cuid())
  name        String
  slug        String                @unique
  description String?
  coverImage  String?
  images      String                @default("[]") // JSON string array of image URLs
  location    String?
  icon        String? // emoji or short icon label
  duration    String? // e.g. "2 hours", "Half day"
  price       Float?
  published   Boolean               @default(false)
  sortOrder   Int                   @default(0)
  metaTitle   String?
  metaDesc    String?
  ogImage     String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  destinations ActivityDestination[]
  tours        ActivityTour[]

  @@index([slug])
  @@index([published])
}

model ActivityDestination {
  activityId    String
  destinationId String
  activity      Activity    @relation(fields: [activityId], references: [id], onDelete: Cascade)
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@id([activityId, destinationId])
  @@index([destinationId])
}

model ActivityTour {
  activityId String
  tourId     String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  tour       Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@id([activityId, tourId])
  @@index([tourId])
}

model Tour {
  id           String            @id @default(cuid())
  title        String
  slug         String            @unique
  excerpt      String?
  description  String?
  category     TourCategory
  duration     Int
  coverImage   String?
  badge        String?
  badgeColor   String?           @default("green")
  gallery      String            @default("[]")
  itinerary    String            @default("[]")
  inclusions   String            @default("[]")
  exclusions   String            @default("[]")
  priceFrom    Float
  priceWas     Float?
  discountPct  Int?
  bestseller   Boolean           @default(false)
  rating       Float             @default(0)
  reviewCount  Int               @default(0)
  published    Boolean           @default(false)
  // Which lead-capture forms render on the public tour-detail page.
  formMode     TourFormMode      @default(BOTH)
  metaTitle    String?
  metaDesc     String?
  ogImage      String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  bestTime     String?
  difficulty   String?
  faqs         String            @default("[]")
  happyCount   Int?
  highlights   String            @default("[]")
  pickupDrop   String?
  startCity    String?
  tagline      String?
  tourType     String?
  transport    String?
  bookings     Booking[]
  reviews      Review[]
  destinations TourDestination[]
  activities   ActivityTour[]

  @@index([slug])
  @@index([category])
  @@index([published])
  @@index([bestseller])
}

model TourDestination {
  id            String      @id @default(cuid())
  tourId        String
  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  tour          Tour        @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([tourId, destinationId])
  @@index([tourId])
  @@index([destinationId])
}

model Booking {
  id              String        @id @default(cuid())
  // Optional: lead-converted bookings have no tour and no Razorpay order.
  tourId          String?
  userId          String?
  status          BookingStatus @default(PENDING)
  razorpayOrderId String?       @unique
  razorpayPayId   String?
  // Canonical total booking amount (negotiated amount for leads; package price
  // for direct website bookings). Financials always derive from this + payments.
  amount          Float
  currency        String        @default("INR")
  // Customer's chosen online-payment option: "ADVANCE" (10% now) or "FULL".
  // Amounts are always derived server-side; this only records the choice.
  paymentOption   String?
  travelDate      DateTime
  travelEndDate   DateTime?
  travellers      Int           @default(1)
  guestName       String
  guestEmail      String?
  guestPhone      String
  // Customer-supplied billing address + free-text custom requirements (direct
  // website bookings). Optional; lead-converted bookings leave these null.
  address         String?
  requirements    String?
  // Discount applied to the booking total. type: "FLAT" | "PERCENT".
  discountType    String?
  discountValue   Float         @default(0)
  // Free-form inclusion tags (e.g. Meals, Cab) stored as a JSON string array.
  inclusions      String        @default("[]")
  // Once locked, services can no longer be added/edited/deleted.
  servicesLocked  Boolean       @default(false)
  // Assigned driver/vehicle, added by staff after services are locked. Editable
  // only until one day before travelDate. driverAddedAt non-null = details exist.
  driverName      String?
  driverPhone     String?
  vehicleNumber   String?
  vehicleName     String?
  driverAddedAt   DateTime?
  // Soft-delete marker. Non-null = hidden from all listings/reports but the row
  // (and its payments/services) is retained. Permanent delete removes the row.
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tour            Tour?         @relation(fields: [tourId], references: [id])
  user            User?         @relation(fields: [userId], references: [id])
  leads           Lead[]
  payments        BookingPayment[]
  services        BookingService[]
  itinerary       Itinerary?

  @@index([status])
  @@index([tourId])
  @@index([userId])
  @@index([createdAt])
}

// A single payment entry against a booking — the booking payment ledger.
// Supports token/advance, partial, and final payments (any number of rows).
model BookingPayment {
  id           String      @id @default(cuid())
  bookingId    String
  booking      Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount       Float
  type         PaymentType @default(PARTIAL)
  method       String? // cash / upi / card / razorpay / bank …
  reference    String? // gateway id, txn ref …
  // Razorpay record for online payments (null for staff-entered cash/UPI etc.).
  // `reference` holds the payment id; these hold the rest of the gateway record.
  gatewayOrderId   String?
  gatewaySignature String?
  metadata         String? // JSON blob of gateway metadata (method, bank, etc.)
  note         String?
  // GST applies only to non-cash payments and is optional. Both the selected
  // percent and the computed value are persisted so future booking-wise and
  // payment-wise GST reports need no recomputation. Null for cash / no GST.
  gstPercent   Float?
  gstAmount    Float?
  recordedById String?
  createdAt    DateTime    @default(now())

  @@index([bookingId])
  @@index([createdAt])
}

// A line item in a booking's services sheet. One table covers all kinds; only
// the columns relevant to a kind are populated (others stay null).
model BookingService {
  id        String      @id @default(cuid())
  bookingId String
  booking   Booking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  kind      ServiceKind
  name      String // Hotel name / Cab name / Activity name / Other name
  amount    Float       @default(0)
  location  String? // hotel + activity
  nights    Int? // hotel
  roomType  String? // hotel — e.g. "1 room", "1 room + 1 extra bed", "Family room"
  pickup    String? // transport
  dropoff   String? // transport
  timing    String? // activity
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())

  @@index([bookingId])
}

// Append-only payment audit trail. Records every payment-gateway event (order
// creation, signature verification success/failure, webhook events) for security
// review + dispute resolution. bookingId is a loose reference (no FK) so the
// audit survives a booking deletion. Never throws — best-effort writes.
model PaymentAudit {
  id        String   @id @default(cuid())
  bookingId String?
  event     String // ORDER_CREATED | PAYMENT_VERIFIED | VERIFICATION_FAILED | WEBHOOK_CAPTURED | WEBHOOK_FAILED
  status    String? // success | failed
  orderId   String?
  paymentId String?
  amount    Float?
  ip        String?
  detail    String? // free text / JSON context (never raw secrets)
  createdAt DateTime @default(now())

  @@index([bookingId])
  @@index([event])
  @@index([createdAt])
}

model Lead {
  id           String        @id @default(cuid())
  name         String
  phone        String
  email        String?
  source       LeadSource    @default(WEBSITE)
  // Free-text page/campaign tag (home, tours, blog-detail, …). The LeadSource
  // enum captures the marketing channel; this captures which on-site form fired.
  sourcePage   String?
  category     LeadCategory?
  adults       Int           @default(1)
  children     Int?
  startDate    DateTime?
  endDate      DateTime?
  attachments  String        @default("[]")
  notes        String?
  followUpAt   DateTime?
  assignedToId String?
  assignedTo   User?         @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  status       LeadStatus    @default(NEW)
  bookingId        String?
  booking          Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  negotiatedAmount Float?
  tokenAmount      Float?
  // Set true on conversion; blocks lead/itinerary edits until an admin unlocks.
  locked           Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  activities   LeadActivity[]
  itinerary    Itinerary?

  @@index([status])
  @@index([source])
  @@index([category])
  @@index([assignedToId])
  @@index([createdAt])
  @@index([followUpAt])
  // Public-form dedupe looks up the most recent lead by normalized phone/email.
  @@index([phone])
  @@index([email])
}

model LeadActivity {
  id              String           @id @default(cuid())
  leadId          String
  lead            Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type            LeadActivityType
  note            String?
  fromStatus      LeadStatus?
  toStatus        LeadStatus?
  fromAssigneeId  String?
  toAssigneeId    String?
  performedById   String?
  performedByName String
  performedAt     DateTime         @default(now())

  @@index([leadId])
  @@index([performedAt])
}

model Review {
  id        String   @id @default(cuid())
  tourId    String
  userId    String?
  name      String
  avatar    String? // reviewer picture; admin-set per review, overrides the user's profile image
  rating    Int
  body      String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tour      Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  // A signed-in customer may review a given tour only once. Guest reviews have a
  // null userId; Postgres treats NULLs as distinct, so this never blocks them.
  @@unique([userId, tourId])
  @@index([tourId])
  @@index([approved])
}

model Blog {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  body        String?
  coverImage  String?
  author      String?
  category    String?
  readTime    Int?
  published   Boolean   @default(false)
  publishedAt DateTime?
  metaTitle   String?
  metaDesc    String?
  ogImage     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  authorImage String?
  featured    Boolean   @default(false)
  trending    Boolean   @default(false)
  authorBio   String?
  authorRole  String?

  @@index([slug])
  @@index([published])
  @@index([publishedAt])
  @@index([featured])
  @@index([trending])
  @@index([category])
}

